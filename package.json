{
  "name": "complifit-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/server.cjs --external:pg-native --external:fsevents --external:firebase-admin --external:@google-cloud/text-to-speech --external:@google-cloud/storage --external:nodemailer",
    "start": "node dist/server.cjs",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.0.1",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.90.1",
    "bcryptjs": "^2.4.3",
    "dns": "^0.2.2",
    "dotenv": "^16.6.1",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.0",
    "firebase-admin": "^13.6.1",
    "googleapis": "^170.0.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.0",
    "pg": "^8.13.1",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.15.6",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.27.2",
    "eslint": "^8.57.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.2",
    "tsx": "^4.19.1",
    "typescript": "^5.8.2"
  }
}
