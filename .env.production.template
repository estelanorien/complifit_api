# Production Environment Variables Template
# Bu dosyayı kopyalayıp değerleri doldurun
# Cloud Run'da Environment Variables olarak ayarlayın
# VEYA Secret Manager kullanın (daha güvenli)

# ============================================
# ZORUNLU DEĞİŞKENLER
# ============================================

# Node Environment
NODE_ENV=production

# Database Connection String
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Cloud SQL Proxy ile: postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
DATABASE_URL=postgresql://vitality_user:YOUR_PASSWORD@YOUR_HOST:5432/vitality_db

# JWT Secret (Minimum 32 karakter - güçlü random string)
# Oluşturmak için: openssl rand -hex 32
JWT_SECRET=YOUR_JWT_SECRET_MINIMUM_32_CHARACTERS_HERE

# Google Gemini API Key
# https://makersuite.google.com/app/apikey adresinden alın
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ============================================
# OPSİYONEL DEĞİŞKENLER
# ============================================

# Google Places API Key (Restaurant özellikleri için)
GOOGLE_PLACES_KEY=YOUR_GOOGLE_PLACES_API_KEY

# CORS Allowed Origins (virgülle ayrılmış)
# Production'da spesifik domain'ler belirtin, * kullanmayın!
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database SSL Configuration
# Cloud SQL Proxy kullanıyorsanız: false
# Public IP ile bağlanıyorsanız: true
DB_SSL_REJECT_UNAUTHORIZED=false

# Port (Cloud Run otomatik ayarlar, genelde değiştirmeye gerek yok)
PORT=8080

# ============================================
# OAUTH / SOCIAL LOGIN (Opsiyonel)
# ============================================

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Facebook OAuth
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET

# Apple OAuth
APPLE_CLIENT_ID=YOUR_APPLE_CLIENT_ID
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID
APPLE_KEY_ID=YOUR_APPLE_KEY_ID

# ============================================
# PUSH NOTIFICATIONS (Opsiyonel)
# ============================================

# VAPID Keys (Web Push için)
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_EMAIL=your-email@example.com

# ============================================
# YOUTUBE INTEGRATION (Opsiyonel)
# ============================================

YOUTUBE_CLIENT_ID=YOUR_YOUTUBE_CLIENT_ID
YOUTUBE_CLIENT_SECRET=YOUR_YOUTUBE_CLIENT_SECRET
YOUTUBE_REFRESH_TOKEN=YOUR_YOUTUBE_REFRESH_TOKEN

# ============================================
# NOTLAR
# ============================================

# 1. Bu dosyayı GIT'e commit ETMEYİN! (.gitignore'da olmalı)
# 2. Production'da Secret Manager kullanın
# 3. Tüm sensitive değerleri Cloud Run Environment Variables'da ayarlayın
# 4. Database connection string'i güvenli tutun
# 5. JWT_SECRET production'da mutlaka 32+ karakter olmalı
